ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=10080

# Upstage Solar
UPSTAGE_API_KEY=
LLM_MODEL=solar-pro3
EMBEDDING_MODEL=solar-embedding-1-large
EMBEDDING_DIMENSION=4096

# 네이버 검색 API (뉴스)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 전자공시 OpenDART
DART_API_KEY=

# pykrx (PER/PBR 및 임의 종목명 검색에만 필요)
KRX_ID=
KRX_PW=

# Supabase (RAG / 저장)
SUPABASE_URL=
SUPABASE_KEY=

# RAG
RAG_CHUNK_SIZE=1600
RAG_CHUNK_OVERLAP=200
RAG_EMBEDDING_BATCH_SIZE=16

# Frontend
VITE_API_BASE=http://127.0.0.1:8000/api/v1
FRONTEND_PORT=80
BACKEND_PORT=8000
